{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "habit-tracker",
    "compatibility_date": "2025-02-27",
    "observability": {
        "enabled": true
    },
    "assets": {
        "directory": "dist",
        "binding": "ASSETS",
        "not_found_handling": "single-page-application"
    },
    "compatibility_flags": [
        "nodejs_compat"
    ]
}